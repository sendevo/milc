{
    "before-milking-start": {
        "id": "before-milking-start",
        "title": { "en": "Before Milking", "es": "Antes de ordeñar" },
        "subtitle": { "en": "Have you cleaned the space?", "es": "¿Limpiaste la sala?" },
        "showDate": true,
        "icon": "shroom.png",
        "fields": [{
            "id": "udder_clean",
            "type": "select",
            "action": "log_value",
            "options": [
                { "value": "yes", "label": { "en": "Yes", "es": "Sí" } },
                { "value": "no", "label": { "en": "No", "es": "No" } },
                { "value": "dont_know", "label": { "en": "Don't know", "es": "No sé" } }
            ]
        }],
        "next": {
            "field": "udder_clean",
            "map": {
                "yes": "before-milking-start-animal-count",
                "no": "before-milking-start-animal-count",
                "dont_know": "before-milking-start-parlor-tip"
            }
        }
    },

    "before-milking-start-parlor-tip": {
        "id": "before-milking-start-parlor-tip",
        "title": { "en": "Before Milking", "es": "Antes de ordeñar" },
        "fields": [{
            "id": "my_images",
            "type": "image_list",
            "images": [
                { "src": "parlor_1.png" },
                { "src": "milk_tanks.png" }
            ]
        }],
        "next": null
    },

    "before-milking-start-animal-count": {
        "id": "before-milking-start-animal-count",
        "title": { "en": "Animal Count", "es": "Conteo de animales" },
        "subtitle": { "en": "Number of animals being milked", "es": "Cantidad de animales en ordeñe" },
        "fields": [{
            "id": "animal_count",
            "type": "number_input",
            "action": "save_to_storage",
            "label": { "en": "Number of animals being milked", "es": "Cantidad de animales en ordeñe" },
            "default": 1,
            "min": 1,
            "step": 1
        }],
        "next": null
    }
}