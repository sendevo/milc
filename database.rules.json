{
  "rules": {
    "survey": {
      ".read":  "auth != null",
      ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous'"
    },
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
